# Copy to .env and adjust if needed (used by local `npm run dev` in frontend/)

# Nakama API + WebSocket (browser must reach this host; use localhost with Docker published ports)
VITE_NAKAMA_HOST=localhost
VITE_NAKAMA_PORT=7350
VITE_NAKAMA_SERVER_KEY=defaultkey
VITE_NAKAMA_USE_SSL=false

# Nakama console (docker-compose publishes 7351)
# Open http://localhost:7351 — default in local.yml: admin / password
